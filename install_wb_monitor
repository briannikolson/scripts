#!/bin/bash
# ============================================================================
# WB Monitor
# ============================================================================

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}========================================${NC}"
echo -e "${GREEN}WB Monitor - Автоматическая установка${NC}"
echo -e "${GREEN}========================================${NC}"

# ============================================================================
# 1. ПОИСК ZABBIX AGENT НА VPS
# ============================================================================
echo -e "\n${YELLOW}[1/6] Поиск Zabbix Agent на VPS...${NC}"

AGENT_TYPE=""
AGENT_PATH=""
AGENT_CONF_DIR=""
AGENT_SERVICE=""

PATHS=(
    "/usr/sbin/zabbix_agentd"
    "/usr/sbin/zabbix_agent2"
    "/usr/local/sbin/zabbix_agentd"
    "/usr/local/sbin/zabbix_agent2"
    "/opt/zabbix/sbin/zabbix_agentd"
    "/opt/zabbix/sbin/zabbix_agent2"
)

for p in "${PATHS[@]}"; do
    if [ -x "$p" ]; then
        AGENT_PATH="$p"
        if [[ "$p" == *"agent2"* ]]; then
            AGENT_TYPE="zabbix_agent2"
        else
            AGENT_TYPE="zabbix_agentd"
        fi
        echo -e "${GREEN}✓ Найден агент: $AGENT_PATH${NC}"
        break
    fi
done

if [ -z "$AGENT_PATH" ]; then
    if command -v zabbix_agentd >/dev/null 2>&1; then
        AGENT_PATH=$(command -v zabbix_agentd)
        AGENT_TYPE="zabbix_agentd"
        echo -e "${GREEN}✓ Найден агент: $AGENT_PATH${NC}"
    elif command -v zabbix_agent2 >/dev/null 2>&1; then
        AGENT_PATH=$(command -v zabbix_agent2)
        AGENT_TYPE="zabbix_agent2"
        echo -e "${GREEN}✓ Найден агент: $AGENT_PATH${NC}"
    fi
fi

if [ -z "$AGENT_PATH" ]; then
    echo -e "${RED}✗ Zabbix Agent не найден на этой VPS${NC}"
    exit 1
fi

AGENT_VERSION=$($AGENT_PATH --version 2>/dev/null | head -1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
echo -e "${GREEN}✓ Версия агента: $AGENT_VERSION${NC}"

# ============================================================================
# 2. ПОИСК СЕРВИСА (УЛУЧШЕННАЯ ВЕРСИЯ)
# ============================================================================
echo -e "\n${YELLOW}[2/6] Поиск сервиса Zabbix Agent...${NC}"

# Расширенный список возможных имен сервисов
POSSIBLE_SERVICES=(
    "zabbix-agent2"
    "zabbix-agent"
    "zabbix_agentd"
    "zabbix-agent2.service"
    "zabbix-agent.service"
    "zabbix_agentd.service"
)

# 1. Пробуем найти через systemctl
for svc in "${POSSIBLE_SERVICES[@]}"; do
    # Убираем .service для поиска
    svc_name="${svc%.service}"
    if systemctl list-units --type=service 2>/dev/null | grep -q "${svc_name}.service"; then
        AGENT_SERVICE="${svc_name}.service"
        echo -e "${GREEN}✓ Найден сервис: $AGENT_SERVICE${NC}"
        break
    fi
done

# 2. Если не нашли через systemctl, проверяем init.d
if [ -z "$AGENT_SERVICE" ]; then
    if [ -f "/etc/init.d/zabbix-agent" ]; then
        AGENT_SERVICE="zabbix-agent"
        echo -e "${GREEN}✓ Найден init.d сервис: $AGENT_SERVICE${NC}"
    elif [ -f "/etc/init.d/zabbix-agent2" ]; then
        AGENT_SERVICE="zabbix-agent2"
        echo -e "${GREEN}✓ Найден init.d сервис: $AGENT_SERVICE${NC}"
    elif [ -f "/etc/init.d/zabbix_agentd" ]; then
        AGENT_SERVICE="zabbix_agentd"
        echo -e "${GREEN}✓ Найден init.d сервис: $AGENT_SERVICE${NC}"
    fi
fi

# 3. Если все равно не нашли, создаем на основе типа агента
if [ -z "$AGENT_SERVICE" ]; then
    if [ "$AGENT_TYPE" = "zabbix_agent2" ]; then
        AGENT_SERVICE="zabbix-agent2"
    else
        AGENT_SERVICE="zabbix-agent"
    fi
    echo -e "${YELLOW}⚠ Сервис не найден, предполагается: $AGENT_SERVICE${NC}"
fi

# ============================================================================
# 3. ПОИСК ДИРЕКТОРИИ КОНФИГОВ
# ============================================================================
echo -e "\n${YELLOW}[3/6] Поиск директории конфигов...${NC}"

CONF_DIRS=(
    "/etc/zabbix/zabbix_agentd.d"
    "/etc/zabbix/zabbix_agent2.d"
    "/usr/local/etc/zabbix_agentd.d"
    "/etc/zabbix"
)

for dir in "${CONF_DIRS[@]}"; do
    if [ -d "$dir" ]; then
        AGENT_CONF_DIR="$dir"
        echo -e "${GREEN}✓ Найдена конфигурация: $AGENT_CONF_DIR${NC}"
        break
    fi
done

if [ -z "$AGENT_CONF_DIR" ]; then
    AGENT_CONF_DIR="/etc/zabbix/zabbix_agentd.d"
    mkdir -p "$AGENT_CONF_DIR"
    echo -e "${YELLOW}✓ Создана директория: $AGENT_CONF_DIR${NC}"
fi

# ============================================================================
# 4. СОЗДАНИЕ СКРИПТА МОНИТОРИНГА
# ============================================================================
echo -e "\n${YELLOW}[4/6] Создание скрипта мониторинга...${NC}"

cat > /usr/local/bin/wb_monitor.sh << 'MONITOR_EOF'
#!/bin/bash
# WB Monitor - Мониторинг Wildberries

TARGET="wildberries.ru"
PING_COUNT=20
PING_TIMEOUT=2
CURL_TIMEOUT=10
CURL_CONNECT_TIMEOUT=5

get_packet_loss() {
    local loss=$(ping -c "$PING_COUNT" -W "$PING_TIMEOUT" "$TARGET" 2>/dev/null | grep -oE '[0-9]+(?=% packet loss)' | head -1)
    echo ${loss:-100}
}

get_ping_time() {
    local times=$(ping -c "$PING_COUNT" -W "$PING_TIMEOUT" "$TARGET" 2>/dev/null | grep -oE 'time=[0-9.]+' | cut -d= -f2)
    if [ -n "$times" ]; then
        local sum=0; local count=0
        for t in $times; do sum=$(echo "$sum + $t" | bc); count=$((count + 1)); done
        printf "%.2f" "$(echo "scale=2; $sum / $count" | bc)"
    else
        echo "0"
    fi
}

get_http_code() {
    local code=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout "$CURL_CONNECT_TIMEOUT" --max-time "$CURL_TIMEOUT" "https://$TARGET" 2>/dev/null)
    echo ${code:-0}
}

get_http_time() {
    local time_total=$(curl -s -o /dev/null -w "%{time_total}" --connect-timeout "$CURL_CONNECT_TIMEOUT" --max-time "$CURL_TIMEOUT" "https://$TARGET" 2>/dev/null)
    printf "%.3f" "${time_total:-0}"
}

case "$1" in
    --loss) get_packet_loss ;;
    --ping-time) get_ping_time ;;
    --http-code) get_http_code ;;
    --http-time) get_http_time ;;
    --all) echo "loss=$(get_packet_loss) ping_time=$(get_ping_time) http_code=$(get_http_code) http_time=$(get_http_time)" ;;
    *) exit 1 ;;
esac
MONITOR_EOF

chmod +x /usr/local/bin/wb_monitor.sh
echo -e "${GREEN}✓ Скрипт создан: /usr/local/bin/wb_monitor.sh${NC}"

# ============================================================================
# 5. НАСТРОЙКА ZABBIX AGENT
# ============================================================================
echo -e "\n${YELLOW}[5/6] Настройка Zabbix Agent...${NC}"

CONF_FILE="$AGENT_CONF_DIR/wb_monitor.conf"

cat > "$CONF_FILE" << 'CONF_EOF'
# WB Monitor - Wildberries monitoring
UserParameter=wb.loss, /usr/local/bin/wb_monitor.sh --loss
UserParameter=wb.ping.time, /usr/local/bin/wb_monitor.sh --ping-time
UserParameter=wb.http.code, /usr/local/bin/wb_monitor.sh --http-code
UserParameter=wb.http.time, /usr/local/bin/wb_monitor.sh --http-time
CONF_EOF

echo -e "${GREEN}✓ Конфиг создан: $CONF_FILE${NC}"

# ============================================================================
# 6. ПЕРЕЗАПУСК АГЕНТА (УЛУЧШЕННАЯ ВЕРСИЯ)
# ============================================================================
echo -e "\n${YELLOW}[6/6] Перезапуск Zabbix Agent...${NC}"

RESTART_SUCCESS=0

# Способ 1: через systemctl с правильным именем
if [ -n "$AGENT_SERVICE" ]; then
    if systemctl restart "$AGENT_SERVICE" 2>/dev/null; then
        echo -e "${GREEN}✓ Агент перезапущен через systemctl: $AGENT_SERVICE${NC}"
        RESTART_SUCCESS=1
    fi
fi

# Способ 2: перебор возможных имен сервисов
if [ $RESTART_SUCCESS -eq 0 ]; then
    for svc in zabbix-agent2 zabbix-agent zabbix_agentd; do
        if systemctl restart "$svc" 2>/dev/null; then
            echo -e "${GREEN}✓ Агент перезапущен через systemctl: $svc${NC}"
            RESTART_SUCCESS=1
            break
        fi
    done
fi

# Способ 3: через service command
if [ $RESTART_SUCCESS -eq 0 ]; then
    if command -v service >/dev/null 2>&1; then
        for svc in zabbix-agent2 zabbix-agent zabbix_agentd; do
            if service "$svc" restart 2>/dev/null; then
                echo -e "${GREEN}✓ Агент перезапущен через service: $svc${NC}"
                RESTART_SUCCESS=1
                break
            fi
        done
    fi
fi

# Способ 4: через kill -HUP
if [ $RESTART_SUCCESS -eq 0 ]; then
    if [ -n "$AGENT_PATH" ]; then
        pkill -HUP -f "$AGENT_PATH" 2>/dev/null
        echo -e "${GREEN}✓ Агент перезапущен через HUP сигнал${NC}"
        RESTART_SUCCESS=1
    fi
fi

if [ $RESTART_SUCCESS -eq 0 ]; then
    echo -e "${YELLOW}⚠ Не удалось перезапустить агент автоматически${NC}"
    echo -e "${YELLOW}Пожалуйста, перезапустите Zabbix Agent вручную:${NC}"
    echo -e "  systemctl restart zabbix-agent2  # или zabbix-agent"
fi

sleep 2

# ============================================================================
# 7. ПРОВЕРКА РАБОТОСПОСОБНОСТИ
# ============================================================================
echo -e "\n${YELLOW}Проверка работоспособности...${NC}"

echo -e "\n${YELLOW}Результаты мониторинга:${NC}"
/usr/local/bin/wb_monitor.sh --all

echo -e "\n${GREEN}========================================${NC}"
echo -e "${GREEN}УСТАНОВКА ЗАВЕРШЕНА!${NC}"
echo -e "${GREEN}========================================${NC}"
echo -e ""
echo -e "Информация о Zabbix Agent:"
echo -e "  Тип:      $AGENT_TYPE"
echo -e "  Путь:     $AGENT_PATH"
echo -e "  Версия:   $AGENT_VERSION"
echo -e "  Конфиг:   $CONF_FILE"
echo -e "  Сервис:   ${AGENT_SERVICE:-не определен, перезапустите вручную}"
echo -e ""
echo -e "Доступные метрики: wb.loss, wb.ping.time, wb.http.code, wb.http.time"
