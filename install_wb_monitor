#!/bin/bash

# Парсинг аргументов
WB_MONITOR_VERSION="5.0"
GITHUB_URL="https://raw.githubusercontent.com/briannikolson/scripts/refs/heads/main/install_wb_monitor"

# Цвета
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "WB Monitor v$WB_MONITOR_VERSION - Установка"

# ============================================================================
# 1. ОПРЕДЕЛЕНИЕ ОС
# ============================================================================
if [ -f /etc/os-release ]; then
    . /etc/os-release
    OS_ID=$ID
    OS_VERSION=$VERSION_ID
else
    echo "ERROR: не удалось определить ОС"
    exit 1
fi

if command -v dnf &>/dev/null; then
    PKG_MANAGER="dnf"
elif command -v yum &>/dev/null; then
    PKG_MANAGER="yum"
elif command -v apt &>/dev/null; then
    PKG_MANAGER="apt"
elif command -v apk &>/dev/null; then
    PKG_MANAGER="apk"
elif command -v pacman &>/dev/null; then
    PKG_MANAGER="pacman"
else
    echo "ERROR: не найден пакетный менеджер"
    exit 1
fi

echo "ОС: $OS_ID $OS_VERSION, пакетный менеджер: $PKG_MANAGER"

# ============================================================================
# 2. УСТАНОВКА ЗАВИСИМОСТЕЙ
# ============================================================================
for pkg in curl bc; do
    if ! command -v $pkg >/dev/null 2>&1; then
        echo "Установка $pkg..."
        case $PKG_MANAGER in
            apt)    apt update && apt install -y $pkg ;;
            yum|dnf) $PKG_MANAGER install -y $pkg ;;
            apk)    apk add $pkg ;;
            pacman) pacman -S --noconfirm $pkg ;;
        esac
    else
        echo "$pkg уже установлен"
    fi
done

# ============================================================================
# 3. ПОИСК ZABBIX AGENT
# ============================================================================
AGENT_SERVICE=""
AGENT_CONF_DIR=""

# Ждём запуска агента если он только установлен
for i in $(seq 1 5); do
    if systemctl is-active --quiet zabbix-agent2; then
        AGENT_SERVICE="zabbix-agent2"
        break
    elif systemctl is-active --quiet zabbix-agent; then
        AGENT_SERVICE="zabbix-agent"
        break
    fi
    echo "Ожидание запуска Zabbix Agent... ($i/5)"
    sleep 3
done

# Если сервис не активен — ищем бинарник
if [ -z "$AGENT_SERVICE" ]; then
    if command -v zabbix_agent2 >/dev/null 2>&1 || [ -f /usr/sbin/zabbix_agent2 ]; then
        AGENT_SERVICE="zabbix-agent2"
        echo "zabbix-agent2 найден но не запущен"
    elif command -v zabbix_agentd >/dev/null 2>&1 || [ -f /usr/sbin/zabbix_agentd ]; then
        AGENT_SERVICE="zabbix-agent"
        echo "zabbix-agent найден но не запущен"
    else
        echo "ERROR: Zabbix Agent не найден"
        exit 1
    fi
fi

echo "Найден: $AGENT_SERVICE"

# Поиск директории конфигов
for dir in /etc/zabbix/zabbix_agent2.d /etc/zabbix/zabbix_agentd.d /etc/zabbix; do
    if [ -d "$dir" ]; then
        AGENT_CONF_DIR="$dir"
        break
    fi
done

if [ -z "$AGENT_CONF_DIR" ]; then
    AGENT_CONF_DIR="/etc/zabbix/zabbix_agent2.d"
    mkdir -p "$AGENT_CONF_DIR"
    echo "Директория создана: $AGENT_CONF_DIR"
fi

echo "Директория конфигов: $AGENT_CONF_DIR"

# ============================================================================
# 4. СОЗДАНИЕ СКРИПТА МОНИТОРИНГА
# ============================================================================
cat > /usr/local/bin/wb_monitor.sh << 'MONITOR_EOF'
#!/bin/bash
# WB Monitor v5.0

declare -A SERVICES=(
    ["main"]="wildberries.ru"
    ["card"]="u-card.wb.ru"
    ["search"]="u-search.wb.ru"
)

PING_COUNT=5
PING_TIMEOUT=2
CURL_TIMEOUT=10
USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"

get_packet_loss() {
    local target=$1
    local out=$(ping -c "$PING_COUNT" -W "$PING_TIMEOUT" "$target" 2>/dev/null)
    local loss=$(echo "$out" | grep -oE '[0-9]+%' | grep -oE '[0-9]+' | head -1)
    [ -z "$loss" ] && { echo "$out" | grep -q "bytes from" && loss="0" || loss="100"; }
    echo "$loss"
}

get_ping_time() {
    local target=$1
    local times=$(ping -c "$PING_COUNT" -W "$PING_TIMEOUT" "$target" 2>/dev/null | grep -oE 'time=[0-9.]+' | cut -d= -f2)
    if [ -n "$times" ]; then
        local sum=0; local cnt=0
        for t in $times; do sum=$(echo "$sum + $t" | bc); cnt=$((cnt + 1)); done
        printf "%.2f" "$(echo "scale=2; $sum / $cnt" | bc)"
    else echo "0"; fi
}

get_ping_min() {
    local target=$1
    local min=$(ping -c "$PING_COUNT" -W "$PING_TIMEOUT" "$target" 2>/dev/null | grep -oE 'time=[0-9.]+' | cut -d= -f2 | sort -n | head -1)
    echo "${min:-0}"
}

get_ping_max() {
    local target=$1
    local max=$(ping -c "$PING_COUNT" -W "$PING_TIMEOUT" "$target" 2>/dev/null | grep -oE 'time=[0-9.]+' | cut -d= -f2 | sort -n | tail -1)
    echo "${max:-0}"
}

get_http_code() {
    local target=$1
    local code=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 5 --max-time 10 -A "$USER_AGENT" "https://$target" 2>/dev/null)
    echo ${code:-0}
}

get_http_time() {
    local target=$1
    local time=$(curl -s -o /dev/null -w "%{time_total}" --connect-timeout 5 --max-time 10 -A "$USER_AGENT" "https://$target" 2>/dev/null)
    printf "%.3f" "${time:-0}"
}

get_status() {
    local loss=$(get_packet_loss "${SERVICES[main]}")
    local code=$(get_http_code "${SERVICES[main]}")
    if [ "$loss" = "0" ] && [ "$code" != "0" ]; then echo "OK"
    elif [ "$loss" = "100" ] && [ "$code" = "0" ]; then echo "DOWN"
    else echo "PARTIAL"; fi
}

case "$1" in
    --loss)              get_packet_loss "${SERVICES[main]}" ;;
    --ping-time)         get_ping_time   "${SERVICES[main]}" ;;
    --ping-min)          get_ping_min    "${SERVICES[main]}" ;;
    --ping-max)          get_ping_max    "${SERVICES[main]}" ;;
    --http-code)         get_http_code   "${SERVICES[main]}" ;;
    --http-time)         get_http_time   "${SERVICES[main]}" ;;
    --status)            get_status ;;
    --main-loss)         get_packet_loss "${SERVICES[main]}" ;;
    --main-ping-time)    get_ping_time   "${SERVICES[main]}" ;;
    --main-ping-min)     get_ping_min    "${SERVICES[main]}" ;;
    --main-ping-max)     get_ping_max    "${SERVICES[main]}" ;;
    --main-http-code)    get_http_code   "${SERVICES[main]}" ;;
    --main-http-time)    get_http_time   "${SERVICES[main]}" ;;
    --card-loss)         get_packet_loss "${SERVICES[card]}" ;;
    --card-ping-time)    get_ping_time   "${SERVICES[card]}" ;;
    --card-ping-min)     get_ping_min    "${SERVICES[card]}" ;;
    --card-ping-max)     get_ping_max    "${SERVICES[card]}" ;;
    --card-http-code)    get_http_code   "${SERVICES[card]}" ;;
    --card-http-time)    get_http_time   "${SERVICES[card]}" ;;
    --search-loss)       get_packet_loss "${SERVICES[search]}" ;;
    --search-ping-time)  get_ping_time   "${SERVICES[search]}" ;;
    --search-ping-min)   get_ping_min    "${SERVICES[search]}" ;;
    --search-ping-max)   get_ping_max    "${SERVICES[search]}" ;;
    --search-http-code)  get_http_code   "${SERVICES[search]}" ;;
    --search-http-time)  get_http_time   "${SERVICES[search]}" ;;
    --all)
        echo "=== MAIN ===";   echo "loss=$(get_packet_loss ${SERVICES[main]})   ping_time=$(get_ping_time ${SERVICES[main]})   ping_min=$(get_ping_min ${SERVICES[main]})   ping_max=$(get_ping_max ${SERVICES[main]})   http_code=$(get_http_code ${SERVICES[main]})   http_time=$(get_http_time ${SERVICES[main]})"
        echo "=== CARD ===";   echo "loss=$(get_packet_loss ${SERVICES[card]})   ping_time=$(get_ping_time ${SERVICES[card]})   ping_min=$(get_ping_min ${SERVICES[card]})   ping_max=$(get_ping_max ${SERVICES[card]})   http_code=$(get_http_code ${SERVICES[card]})   http_time=$(get_http_time ${SERVICES[card]})"
        echo "=== SEARCH ==="; echo "loss=$(get_packet_loss ${SERVICES[search]}) ping_time=$(get_ping_time ${SERVICES[search]}) ping_min=$(get_ping_min ${SERVICES[search]}) ping_max=$(get_ping_max ${SERVICES[search]}) http_code=$(get_http_code ${SERVICES[search]}) http_time=$(get_http_time ${SERVICES[search]})"
        ;;
    --version) echo "5.0" ;;
    *) exit 1 ;;
esac
MONITOR_EOF

chmod +x /usr/local/bin/wb_monitor.sh
echo "Скрипт создан: /usr/local/bin/wb_monitor.sh"

# ============================================================================
# 5. СОЗДАНИЕ КОНФИГА ZABBIX AGENT
# ============================================================================
cat > "$AGENT_CONF_DIR/wb_monitor.conf" << 'CONF_EOF'
UserParameter=wb.loss,              /usr/local/bin/wb_monitor.sh --loss
UserParameter=wb.ping.time,         /usr/local/bin/wb_monitor.sh --ping-time
UserParameter=wb.ping.min,          /usr/local/bin/wb_monitor.sh --ping-min
UserParameter=wb.ping.max,          /usr/local/bin/wb_monitor.sh --ping-max
UserParameter=wb.http.code,         /usr/local/bin/wb_monitor.sh --http-code
UserParameter=wb.http.time,         /usr/local/bin/wb_monitor.sh --http-time
UserParameter=wb.status,            /usr/local/bin/wb_monitor.sh --status
UserParameter=wb.main.loss,         /usr/local/bin/wb_monitor.sh --main-loss
UserParameter=wb.main.ping.time,    /usr/local/bin/wb_monitor.sh --main-ping-time
UserParameter=wb.main.ping.min,     /usr/local/bin/wb_monitor.sh --main-ping-min
UserParameter=wb.main.ping.max,     /usr/local/bin/wb_monitor.sh --main-ping-max
UserParameter=wb.main.http.code,    /usr/local/bin/wb_monitor.sh --main-http-code
UserParameter=wb.main.http.time,    /usr/local/bin/wb_monitor.sh --main-http-time
UserParameter=wb.card.loss,         /usr/local/bin/wb_monitor.sh --card-loss
UserParameter=wb.card.ping.time,    /usr/local/bin/wb_monitor.sh --card-ping-time
UserParameter=wb.card.ping.min,     /usr/local/bin/wb_monitor.sh --card-ping-min
UserParameter=wb.card.ping.max,     /usr/local/bin/wb_monitor.sh --card-ping-max
UserParameter=wb.card.http.code,    /usr/local/bin/wb_monitor.sh --card-http-code
UserParameter=wb.card.http.time,    /usr/local/bin/wb_monitor.sh --card-http-time
UserParameter=wb.search.loss,       /usr/local/bin/wb_monitor.sh --search-loss
UserParameter=wb.search.ping.time,  /usr/local/bin/wb_monitor.sh --search-ping-time
UserParameter=wb.search.ping.min,   /usr/local/bin/wb_monitor.sh --search-ping-min
UserParameter=wb.search.ping.max,   /usr/local/bin/wb_monitor.sh --search-ping-max
UserParameter=wb.search.http.code,  /usr/local/bin/wb_monitor.sh --search-http-code
UserParameter=wb.search.http.time,  /usr/local/bin/wb_monitor.sh --search-http-time
UserParameter=wb.version,           /usr/local/bin/wb_monitor.sh --version
CONF_EOF

echo "Конфиг создан: $AGENT_CONF_DIR/wb_monitor.conf"

# ============================================================================
# 6. АВТООБНОВЛЕНИЕ (systemd timer)
# ============================================================================
cat > /usr/local/bin/update_wb_monitor.sh << 'UPDATE_EOF'
#!/bin/bash
GITHUB_URL="https://raw.githubusercontent.com/briannikolson/scripts/refs/heads/main/install_wb_monitor"
LOCAL="/usr/local/bin/wb_monitor.sh"
LOG="/var/log/wb_monitor_update.log"

echo "$(date) - Checking..." >> "$LOG"
TEMP="/tmp/wb_new.sh"
curl -s --connect-timeout 10 "$GITHUB_URL" -o "$TEMP"
if [ -s "$TEMP" ] && ! cmp -s "$TEMP" "$LOCAL"; then
    echo "$(date) - Updating..." >> "$LOG"
    cp "$LOCAL" "${LOCAL}.bak"
    cp "$TEMP" "$LOCAL"
    chmod +x "$LOCAL"
    systemctl restart zabbix-agent2 2>/dev/null || systemctl restart zabbix-agent 2>/dev/null
    echo "$(date) - Updated to v$(/usr/local/bin/wb_monitor.sh --version)" >> "$LOG"
fi
rm -f "$TEMP"
UPDATE_EOF

chmod +x /usr/local/bin/update_wb_monitor.sh

cat > /etc/systemd/system/wb-monitor-update.service << 'EOF'
[Unit]
Description=WB Monitor Update

[Service]
Type=oneshot
ExecStart=/usr/local/bin/update_wb_monitor.sh
EOF

cat > /etc/systemd/system/wb-monitor-update.timer << 'EOF'
[Unit]
Description=WB Monitor Update Timer

[Timer]
OnCalendar=*:0/5
Persistent=true

[Install]
WantedBy=timers.target
EOF

systemctl daemon-reload
systemctl enable wb-monitor-update.timer
systemctl start wb-monitor-update.timer
echo "Systemd timer настроен (каждые 5 минут)"

# ============================================================================
# ЗАВЕРШЕНИЕ
# ============================================================================
systemctl restart "$AGENT_SERVICE" 2>/dev/null || true

echo "Проверка:"
/usr/local/bin/wb_monitor.sh --all 2>/dev/null | head -15

echo ""
echo "Скрипт:          /usr/local/bin/wb_monitor.sh"
echo "Конфиг:          $AGENT_CONF_DIR/wb_monitor.conf"
echo "Автообновление:  каждые 5 минут (systemd timer)"
echo "Лог:             /var/log/wb_monitor_update.log"
echo ""
echo "Проверка:  /usr/local/bin/wb_monitor.sh --all"
echo "Версия:    /usr/local/bin/wb_monitor.sh --version"
echo "Лог:       tail -f /var/log/wb_monitor_update.log"
