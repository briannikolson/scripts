#!/bin/bash
# ============================================================================
# WB Monitor - Финальная версия 4.1
# Мониторинг Wildberries через ICMP ping и HTTP/HTTPS с User-Agent
# ============================================================================

# ===== НАСТРОЙКИ ============================================================
TARGET="wildberries.ru"
PING_COUNT=10
PING_TIMEOUT=2
CURL_TIMEOUT=10
CURL_CONNECT_TIMEOUT=5

# User-Agent для эмуляции реального браузера
USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/120.0.0.0 Safari/537.36"

# ===== ФУНКЦИЯ: ПОТЕРИ ПАКЕТОВ (ICMP) ========================================
get_packet_loss() {
    local output=$(ping -c "$PING_COUNT" -W "$PING_TIMEOUT" "$TARGET" 2>/dev/null)
    local loss=$(echo "$output" | grep -oE '[0-9]+%' | grep -oE '[0-9]+' | head -1)
    
    if [ -z "$loss" ]; then
        if echo "$output" | grep -q "bytes from"; then
            loss="0"
        else
            loss="100"
        fi
    fi
    echo "$loss"
}

# ===== ФУНКЦИЯ: СРЕДНЕЕ ВРЕМЯ ПИНГА ==========================================
get_ping_time() {
    local times=$(ping -c "$PING_COUNT" -W "$PING_TIMEOUT" "$TARGET" 2>/dev/null | grep -oE 'time=[0-9.]+' | cut -d= -f2)
    
    if [ -n "$times" ]; then
        local sum=0
        local count=0
        for t in $times; do
            sum=$(echo "$sum + $t" | bc)
            count=$((count + 1))
        done
        if [ $count -gt 0 ]; then
            printf "%.2f" "$(echo "scale=2; $sum / $count" | bc)"
        else
            echo "0"
        fi
    else
        echo "0"
    fi
}

# ===== ФУНКЦИЯ: МИНИМАЛЬНОЕ ВРЕМЯ ПИНГА =======================================
get_ping_min() {
    local min_time=$(ping -c "$PING_COUNT" -W "$PING_TIMEOUT" "$TARGET" 2>/dev/null | grep -oE 'time=[0-9.]+' | cut -d= -f2 | sort -n | head -1)
    echo "${min_time:-0}"
}

# ===== ФУНКЦИЯ: МАКСИМАЛЬНОЕ ВРЕМЯ ПИНГА =======================================
get_ping_max() {
    local max_time=$(ping -c "$PING_COUNT" -W "$PING_TIMEOUT" "$TARGET" 2>/dev/null | grep -oE 'time=[0-9.]+' | cut -d= -f2 | sort -n | tail -1)
    echo "${max_time:-0}"
}

# ===== ФУНКЦИЯ: HTTP СТАТУС КОД (с User-Agent) ================================
get_http_code() {
    local code=$(curl -s -o /dev/null -w "%{http_code}" \
        --connect-timeout "$CURL_CONNECT_TIMEOUT" \
        --max-time "$CURL_TIMEOUT" \
        -A "$USER_AGENT" \
        "https://$TARGET" 2>/dev/null)
    
    if [ -n "$code" ] && [ "$code" -gt 0 ] 2>/dev/null; then
        echo "$code"
    else
        echo "0"
    fi
}

# ===== ФУНКЦИЯ: HTTP ВРЕМЯ ОТВЕТА (с User-Agent) ==============================
get_http_time() {
    local time_total=$(curl -s -o /dev/null -w "%{time_total}" \
        --connect-timeout "$CURL_CONNECT_TIMEOUT" \
        --max-time "$CURL_TIMEOUT" \
        -A "$USER_AGENT" \
        "https://$TARGET" 2>/dev/null)
    
    if [ -n "$time_total" ] && [ "$time_total" != "0" ]; then
        printf "%.3f" "$time_total"
    else
        echo "0"
    fi
}

# ===== ФУНКЦИЯ: СТАТУС =======================================================
get_status() {
    local loss=$(get_packet_loss)
    local http_code=$(get_http_code)
    
    if [ "$loss" = "0" ] && [ "$http_code" != "0" ]; then
        echo "OK"
    elif [ "$loss" = "100" ] && [ "$http_code" = "0" ]; then
        echo "DOWN"
    elif [ "$loss" != "100" ] && [ "$http_code" = "0" ]; then
        echo "HTTP_ERROR"
    else
        echo "PARTIAL"
    fi
}

# ===== ФУНКЦИЯ: ВСЕ МЕТРИКИ В ОДНУ СТРОКУ ======================================
get_all_metrics() {
    local loss=$(get_packet_loss)
    local ping_time=$(get_ping_time)
    local ping_min=$(get_ping_min)
    local ping_max=$(get_ping_max)
    local http_code=$(get_http_code)
    local http_time=$(get_http_time)
    local status=$(get_status)
    
    echo "loss=$loss ping_time=$ping_time ping_min=$ping_min ping_max=$ping_max http_code=$http_code http_time=$http_time status=$status"
}

# ===== ФУНКЦИЯ: ВСЕ МЕТРИКИ (МНОГОСТРОЧНЫЙ ВЫВОД) ==============================
get_all_metrics_multi() {
    echo "loss=$(get_packet_loss)"
    echo "ping_time=$(get_ping_time)"
    echo "ping_min=$(get_ping_min)"
    echo "ping_max=$(get_ping_max)"
    echo "http_code=$(get_http_code)"
    echo "http_time=$(get_http_time)"
    echo "status=$(get_status)"
}

# ===== ДИСПЕТЧЕР =============================================================
case "$1" in
    --loss)         get_packet_loss ;;
    --ping-time)    get_ping_time ;;
    --ping-min)     get_ping_min ;;
    --ping-max)     get_ping_max ;;
    --http-code)    get_http_code ;;
    --http-time)    get_http_time ;;
    --status)       get_status ;;
    --all)          get_all_metrics ;;
    --all-multi)    get_all_metrics_multi ;;
    --help|-h)
        cat << 'HELP_EOF'
╔══════════════════════════════════════════════════════════════════════════════╗
║                    WB Monitor v4.1 - Справка                                 ║
╠══════════════════════════════════════════════════════════════════════════════╣
║                                                                              ║
║  Использование:                                                              ║
║    wb_monitor.sh --loss         - Потери пакетов (%)                         ║
║    wb_monitor.sh --ping-time    - Среднее время пинга (мс)                   ║
║    wb_monitor.sh --ping-min     - Минимальное время пинга (мс)               ║
║    wb_monitor.sh --ping-max     - Максимальное время пинга (мс)              ║
║    wb_monitor.sh --http-code    - HTTP статус код (200, 307, 0)              ║
║    wb_monitor.sh --http-time    - Время HTTP ответа (сек)                    ║
║    wb_monitor.sh --status       - Общий статус (OK/DOWN/PARTIAL)             ║
║    wb_monitor.sh --all          - Все метрики в одну строку                  ║
║    wb_monitor.sh --all-multi    - Все метрики (по одной на строку)           ║
║                                                                              ║
║  Примеры:                                                                    ║
║    wb_monitor.sh --all                                                       ║
║    wb_monitor.sh --loss                                                      ║
║    wb_monitor.sh --http-code                                                 ║
║                                                                              ║
╚══════════════════════════════════════════════════════════════════════════════╝
HELP_EOF
        ;;
    *)
        echo "Использование: $0 {--loss|--ping-time|--ping-min|--ping-max|--http-code|--http-time|--status|--all|--all-multi|--help}"
        exit 1
        ;;
esac

exit 0
