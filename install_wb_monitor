#!/bin/bash
# ============================================================================
# WB Monitor - Полная автоматическая установка мониторинга Wildberries
# Версия: 3.0 (Final)
# Описание: Устанавливает зависимости, настраивает Zabbix Agent, создает скрипт
# Поддержка: Ubuntu, Debian, CentOS, RHEL, Rocky, Alma, Alpine, Arch
# ============================================================================

set -e

# Цвета для вывода
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${GREEN}========================================${NC}"
echo -e "${GREEN}WB Monitor - Полная автоматическая установка${NC}"
echo -e "${GREEN}Версия 3.0${NC}"
echo -e "${GREEN}========================================${NC}"

# ============================================================================
# 1. ОПРЕДЕЛЕНИЕ ОС И МЕНЕДЖЕРА ПАКЕТОВ
# ============================================================================
echo -e "\n${BLUE}[1/8] Определение операционной системы...${NC}"

detect_os() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        OS=$ID
        VER=$VERSION_ID
    else
        OS=$(uname -s)
        VER=$(uname -r)
    fi
    
    case $OS in
        ubuntu|debian)
            PKG_MANAGER="apt"
            INSTALL_CMD="apt update && apt install -y"
            ;;
        centos|rhel|rocky|almalinux|fedora)
            PKG_MANAGER="yum"
            INSTALL_CMD="yum install -y"
            if command -v dnf >/dev/null 2>&1; then
                PKG_MANAGER="dnf"
                INSTALL_CMD="dnf install -y"
            fi
            ;;
        alpine)
            PKG_MANAGER="apk"
            INSTALL_CMD="apk add"
            ;;
        arch)
            PKG_MANAGER="pacman"
            INSTALL_CMD="pacman -S --noconfirm"
            ;;
        *)
            OS="linux"
            PKG_MANAGER="unknown"
            INSTALL_CMD=""
            ;;
    esac
    
    echo -e "${GREEN}✓ ОС: $OS${NC}"
    echo -e "${GREEN}✓ Менеджер пакетов: $PKG_MANAGER${NC}"
}

detect_os

# ============================================================================
# 2. УСТАНОВКА НЕОБХОДИМЫХ ПАКЕТОВ
# ============================================================================
echo -e "\n${BLUE}[2/8] Установка необходимых пакетов...${NC}"

install_package() {
    local pkg=$1
    if ! command -v $pkg >/dev/null 2>&1; then
        echo -e "${YELLOW}⚠ Установка $pkg...${NC}"
        case $PKG_MANAGER in
            apt)
                apt update && apt install -y $pkg
                ;;
            yum|dnf)
                $INSTALL_CMD $pkg
                ;;
            apk)
                $INSTALL_CMD $pkg
                ;;
            pacman)
                $INSTALL_CMD $pkg
                ;;
            *)
                echo -e "${RED}✗ Не удалось установить $pkg. Установите вручную.${NC}"
                return 1
                ;;
        esac
        echo -e "${GREEN}✓ $pkg установлен${NC}"
    else
        echo -e "${GREEN}✓ $pkg уже установлен${NC}"
    fi
    return 0
}

# Устанавливаем необходимые пакеты
install_package "ping" || true  # ping обычно уже есть
install_package "curl"
install_package "bc"

# Дополнительно проверяем наличие ping (iputils-ping или inetutils-ping)
if ! command -v ping >/dev/null 2>&1; then
    echo -e "${YELLOW}⚠ Установка ping...${NC}"
    case $PKG_MANAGER in
        apt) apt update && apt install -y iputils-ping ;;
        yum|dnf) $INSTALL_CMD iputils ;;
        apk) $INSTALL_CMD iputils ;;
        pacman) $INSTALL_CMD iputils ;;
    esac
fi

# ============================================================================
# 3. ПОИСК ZABBIX AGENT НА VPS
# ============================================================================
echo -e "\n${BLUE}[3/8] Поиск Zabbix Agent на VPS...${NC}"

AGENT_TYPE=""
AGENT_PATH=""
AGENT_CONF_DIR=""
AGENT_SERVICE=""

# Список возможных путей
PATHS=(
    "/usr/sbin/zabbix_agent2"
    "/usr/sbin/zabbix_agentd"
    "/usr/local/sbin/zabbix_agent2"
    "/usr/local/sbin/zabbix_agentd"
    "/opt/zabbix/sbin/zabbix_agent2"
    "/opt/zabbix/sbin/zabbix_agentd"
)

for p in "${PATHS[@]}"; do
    if [ -x "$p" ]; then
        AGENT_PATH="$p"
        if [[ "$p" == *"agent2"* ]]; then
            AGENT_TYPE="zabbix_agent2"
            AGENT_SERVICE="zabbix-agent2"
        else
            AGENT_TYPE="zabbix_agentd"
            AGENT_SERVICE="zabbix-agent"
        fi
        echo -e "${GREEN}✓ Найден агент: $AGENT_PATH${NC}"
        break
    fi
done

# Если не нашли по путям, ищем через which
if [ -z "$AGENT_PATH" ]; then
    if command -v zabbix_agent2 >/dev/null 2>&1; then
        AGENT_PATH=$(command -v zabbix_agent2)
        AGENT_TYPE="zabbix_agent2"
        AGENT_SERVICE="zabbix-agent2"
        echo -e "${GREEN}✓ Найден агент: $AGENT_PATH${NC}"
    elif command -v zabbix_agentd >/dev/null 2>&1; then
        AGENT_PATH=$(command -v zabbix_agentd)
        AGENT_TYPE="zabbix_agentd"
        AGENT_SERVICE="zabbix-agent"
        echo -e "${GREEN}✓ Найден агент: $AGENT_PATH${NC}"
    fi
fi

# Если не нашли агент
if [ -z "$AGENT_PATH" ]; then
    echo -e "${RED}✗ Zabbix Agent не найден на этой VPS${NC}"
    echo -e "${RED}Пожалуйста, установите Zabbix Agent перед запуском скрипта${NC}"
    exit 1
fi

# Определяем версию агента
AGENT_VERSION=$($AGENT_PATH --version 2>/dev/null | head -1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
echo -e "${GREEN}✓ Версия агента: $AGENT_VERSION${NC}"
echo -e "${GREEN}✓ Сервис: $AGENT_SERVICE${NC}"

# ============================================================================
# 4. ПОИСК ДИРЕКТОРИИ КОНФИГОВ
# ============================================================================
echo -e "\n${BLUE}[4/8] Поиск директории конфигов...${NC}"

# Определяем правильную директорию в зависимости от типа агента
if [ "$AGENT_TYPE" = "zabbix_agent2" ]; then
    CONF_CANDIDATES=(
        "/etc/zabbix/zabbix_agent2.d"
        "/etc/zabbix/zabbix_agentd.d"
        "/usr/local/etc/zabbix_agent2.d"
    )
else
    CONF_CANDIDATES=(
        "/etc/zabbix/zabbix_agentd.d"
        "/etc/zabbix/zabbix_agent2.d"
        "/usr/local/etc/zabbix_agentd.d"
    )
fi

for dir in "${CONF_CANDIDATES[@]}"; do
    if [ -d "$dir" ]; then
        AGENT_CONF_DIR="$dir"
        echo -e "${GREEN}✓ Найдена конфигурация: $AGENT_CONF_DIR${NC}"
        break
    fi
done

# Если не нашли, создаем
if [ -z "$AGENT_CONF_DIR" ]; then
    if [ "$AGENT_TYPE" = "zabbix_agent2" ]; then
        AGENT_CONF_DIR="/etc/zabbix/zabbix_agent2.d"
    else
        AGENT_CONF_DIR="/etc/zabbix/zabbix_agentd.d"
    fi
    mkdir -p "$AGENT_CONF_DIR"
    echo -e "${YELLOW}✓ Создана директория: $AGENT_CONF_DIR${NC}"
fi

# ============================================================================
# 5. СОЗДАНИЕ СКРИПТА МОНИТОРИНГА (ВЕРСИЯ БЕЗ BC ДЛЯ СОВМЕСТИМОСТИ)
# ============================================================================
echo -e "\n${BLUE}[5/8] Создание скрипта мониторинга...${NC}"

cat > /usr/local/bin/wb_monitor.sh << 'MONITOR_EOF'
#!/bin/bash
# WB Monitor - Мониторинг Wildberries (совместимая версия)
# Работает без bc, использует только bash

TARGET="wildberries.ru"
PING_COUNT=20
PING_TIMEOUT=2
CURL_TIMEOUT=10
CURL_CONNECT_TIMEOUT=5

get_packet_loss() {
    local loss=$(ping -c "$PING_COUNT" -W "$PING_TIMEOUT" "$TARGET" 2>/dev/null | grep -oE '[0-9]+(?=% packet loss)' | head -1)
    echo ${loss:-100}
}

get_ping_time() {
    local times=$(ping -c "$PING_COUNT" -W "$PING_TIMEOUT" "$TARGET" 2>/dev/null | grep -oE 'time=[0-9.]+' | cut -d= -f2)
    if [ -n "$times" ]; then
        local sum=0
        local count=0
        for t in $times; do
            local int_part=$(echo $t | cut -d. -f1)
            local frac_part=$(echo $t | cut -d. -f2)
            if [ -z "$frac_part" ]; then
                frac_part=0
            fi
            # Приводим к сотым долям (для точности)
            local value_hundredths=$((int_part * 100 + frac_part))
            sum=$((sum + value_hundredths))
            count=$((count + 1))
        done
        if [ $count -gt 0 ]; then
            local avg_hundredths=$((sum / count))
            local avg_int=$((avg_hundredths / 100))
            local avg_frac=$((avg_hundredths % 100))
            printf "%d.%02d" $avg_int $avg_frac
        else
            echo "0"
        fi
    else
        echo "0"
    fi
}

get_http_code() {
    local code=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout "$CURL_CONNECT_TIMEOUT" --max-time "$CURL_TIMEOUT" "https://$TARGET" 2>/dev/null)
    echo ${code:-0}
}

get_http_time() {
    local time_total=$(curl -s -o /dev/null -w "%{time_total}" --connect-timeout "$CURL_CONNECT_TIMEOUT" --max-time "$CURL_TIMEOUT" "https://$TARGET" 2>/dev/null)
    if [ -n "$time_total" ] && [ "$time_total" != "0" ]; then
        printf "%.3f" "$time_total"
    else
        echo "0"
    fi
}

case "$1" in
    --loss) get_packet_loss ;;
    --ping-time) get_ping_time ;;
    --http-code) get_http_code ;;
    --http-time) get_http_time ;;
    --all)
        echo "loss=$(get_packet_loss) ping_time=$(get_ping_time) http_code=$(get_http_code) http_time=$(get_http_time)"
        ;;
    *) exit 1 ;;
esac
MONITOR_EOF

chmod +x /usr/local/bin/wb_monitor.sh
echo -e "${GREEN}✓ Скрипт создан: /usr/local/bin/wb_monitor.sh${NC}"

# ============================================================================
# 6. НАСТРОЙКА ZABBIX AGENT
# ============================================================================
echo -e "\n${BLUE}[6/8] Настройка Zabbix Agent...${NC}"

CONF_FILE="$AGENT_CONF_DIR/wb_monitor.conf"

cat > "$CONF_FILE" << 'CONF_EOF'
# WB Monitor - Wildberries monitoring
UserParameter=wb.loss, /usr/local/bin/wb_monitor.sh --loss
UserParameter=wb.ping.time, /usr/local/bin/wb_monitor.sh --ping-time
UserParameter=wb.http.code, /usr/local/bin/wb_monitor.sh --http-code
UserParameter=wb.http.time, /usr/local/bin/wb_monitor.sh --http-time
CONF_EOF

echo -e "${GREEN}✓ Конфиг создан: $CONF_FILE${NC}"

# ============================================================================
# 7. ПЕРЕЗАПУСК ZABBIX AGENT
# ============================================================================
echo -e "\n${BLUE}[7/8] Перезапуск Zabbix Agent...${NC}"

RESTART_SUCCESS=0

# Пробуем перезапустить правильный сервис
if systemctl restart "$AGENT_SERVICE" 2>/dev/null; then
    echo -e "${GREEN}✓ Агент перезапущен: systemctl restart $AGENT_SERVICE${NC}"
    RESTART_SUCCESS=1
fi

# Если не получилось, пробуем альтернативные имена
if [ $RESTART_SUCCESS -eq 0 ]; then
    for alt in zabbix-agent2 zabbix-agent zabbix_agentd; do
        if systemctl restart "$alt" 2>/dev/null; then
            echo -e "${GREEN}✓ Агент перезапущен: systemctl restart $alt${NC}"
            AGENT_SERVICE="$alt"
            RESTART_SUCCESS=1
            break
        fi
    done
fi

# Если systemctl не сработал, пробуем service
if [ $RESTART_SUCCESS -eq 0 ] && command -v service >/dev/null 2>&1; then
    for svc in zabbix-agent2 zabbix-agent zabbix_agentd; do
        if service "$svc" restart 2>/dev/null; then
            echo -e "${GREEN}✓ Агент перезапущен: service $svc restart${NC}"
            RESTART_SUCCESS=1
            break
        fi
    done
fi

# Последняя попытка: kill -HUP
if [ $RESTART_SUCCESS -eq 0 ] && [ -n "$AGENT_PATH" ]; then
    pkill -HUP -f "$AGENT_PATH" 2>/dev/null
    echo -e "${GREEN}✓ Агент перезапущен через HUP сигнал${NC}"
    RESTART_SUCCESS=1
fi

if [ $RESTART_SUCCESS -eq 0 ]; then
    echo -e "${YELLOW}⚠ Не удалось перезапустить агент автоматически${NC}"
    echo -e "${YELLOW}Пожалуйста, перезапустите вручную: systemctl restart $AGENT_SERVICE${NC}"
fi

sleep 3

# ============================================================================
# 8. ПРОВЕРКА РАБОТОСПОСОБНОСТИ
# ============================================================================
echo -e "\n${BLUE}[8/8] Проверка работоспособности...${NC}"

echo -e "\n${YELLOW}Результаты мониторинга:${NC}"
/usr/local/bin/wb_monitor.sh --all

echo -e "\n${YELLOW}Проверка через Zabbix Agent:${NC}"
if command -v zabbix_get >/dev/null 2>&1; then
    echo -n "  wb.loss:         "
    zabbix_get -s 127.0.0.1 -k wb.loss 2>/dev/null || echo "недоступно"
    echo -n "  wb.ping.time:    "
    zabbix_get -s 127.0.0.1 -k wb.ping.time 2>/dev/null || echo "недоступно"
    echo -n "  wb.http.code:    "
    zabbix_get -s 127.0.0.1 -k wb.http.code 2>/dev/null || echo "недоступно"
    echo -n "  wb.http.time:    "
    zabbix_get -s 127.0.0.1 -k wb.http.time 2>/dev/null || echo "недоступно"
else
    echo -e "${YELLOW}⚠ zabbix_get не установлен, пропускаем проверку${NC}"
fi

# ============================================================================
# ИТОГОВАЯ ИНФОРМАЦИЯ
# ============================================================================
echo -e "\n${GREEN}========================================${NC}"
echo -e "${GREEN}УСТАНОВКА ЗАВЕРШЕНА УСПЕШНО!${NC}"
echo -e "${GREEN}========================================${NC}"
echo -e ""
echo -e "${BLUE}Информация о Zabbix Agent:${NC}"
echo -e "  Тип:      $AGENT_TYPE"
echo -e "  Путь:     $AGENT_PATH"
echo -e "  Версия:   $AGENT_VERSION"
echo -e "  Сервис:   $AGENT_SERVICE"
echo -e "  Конфиг:   $CONF_FILE"
echo -e ""
echo -e "${BLUE}Доступные метрики в Zabbix:${NC}"
echo -e "  wb.loss        - Потери пакетов (%)"
echo -e "  wb.ping.time   - Среднее время пинга (ms)"
echo -e "  wb.http.code   - HTTP статус код (200=OK, 307=редирект)"
echo -e "  wb.http.time   - Время HTTP ответа (сек)"
echo -e ""
echo -e "${BLUE}Далее в Zabbix Server:${NC}"
echo -e "  1. Импортируйте шаблон Template WB Monitor"
echo -e "  2. Назначьте шаблон на хост этой VPS"
echo -e "  3. Ждите данные через 1-2 минуты"
echo -e ""
echo -e "${GREEN}Готово! 🚀${NC}"
