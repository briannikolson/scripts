#!/bin/bash
# ============================================================================
# WB Monitor v5.0 - Мониторинг Wildberries (основной + карточки + поиск)
# ============================================================================

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${GREEN}========================================${NC}"
echo -e "${GREEN}WB Monitor v5.0 - Финальная установка${NC}"
echo -e "${GREEN}Мониторинг: wildberries.ru + u-card.wb.ru + u-search.wb.ru${NC}"
echo -e "${GREEN}========================================${NC}"

# ============================================================================
# 1. ОПРЕДЕЛЕНИЕ ОС
# ============================================================================
echo -e "\n${BLUE}[1/8] Определение системы...${NC}"

detect_os() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        OS=$ID
    else
        OS=$(uname -s)
    fi
    
    case $OS in
        ubuntu|debian)
            PKG_MANAGER="apt"
            INSTALL_CMD="apt update && apt install -y"
            ;;
        centos|rhel|rocky|almalinux|fedora)
            PKG_MANAGER="yum"
            INSTALL_CMD="yum install -y"
            if command -v dnf >/dev/null 2>&1; then
                PKG_MANAGER="dnf"
                INSTALL_CMD="dnf install -y"
            fi
            ;;
        alpine)
            PKG_MANAGER="apk"
            INSTALL_CMD="apk add"
            ;;
        arch)
            PKG_MANAGER="pacman"
            INSTALL_CMD="pacman -S --noconfirm"
            ;;
        *)
            PKG_MANAGER="unknown"
            INSTALL_CMD=""
            ;;
    esac
    echo -e "${GREEN}✓ ОС: $OS${NC}"
    echo -e "${GREEN}✓ Менеджер пакетов: $PKG_MANAGER${NC}"
}

detect_os

# ============================================================================
# 2. УСТАНОВКА ЗАВИСИМОСТЕЙ
# ============================================================================
echo -e "\n${BLUE}[2/8] Установка зависимостей...${NC}"

install_package() {
    local pkg=$1
    if ! command -v $pkg >/dev/null 2>&1; then
        echo -e "${YELLOW}⚠ Установка $pkg...${NC}"
        case $PKG_MANAGER in
            apt) apt update && apt install -y $pkg ;;
            yum|dnf) $INSTALL_CMD $pkg ;;
            apk) $INSTALL_CMD $pkg ;;
            pacman) $INSTALL_CMD $pkg ;;
            *) echo -e "${RED}✗ Не удалось установить $pkg${NC}" ;;
        esac
        echo -e "${GREEN}✓ $pkg установлен${NC}"
    else
        echo -e "${GREEN}✓ $pkg уже установлен${NC}"
    fi
}

install_package "curl"
install_package "bc"

# ============================================================================
# 3. ПОИСК ZABBIX AGENT
# ============================================================================
echo -e "\n${BLUE}[3/8] Поиск Zabbix Agent...${NC}"

AGENT_PATH=""
AGENT_TYPE=""
AGENT_SERVICE=""
AGENT_CONF_DIR=""

for p in /usr/sbin/zabbix_agent2 /usr/sbin/zabbix_agentd /usr/local/sbin/zabbix_agent2 /usr/local/sbin/zabbix_agentd; do
    if [ -x "$p" ]; then
        AGENT_PATH="$p"
        if [[ "$p" == *"agent2"* ]]; then
            AGENT_TYPE="zabbix_agent2"
            AGENT_SERVICE="zabbix-agent2"
        else
            AGENT_TYPE="zabbix_agentd"
            AGENT_SERVICE="zabbix-agent"
        fi
        echo -e "${GREEN}✓ Найден агент: $AGENT_PATH${NC}"
        break
    fi
done

if [ -z "$AGENT_PATH" ]; then
    if command -v zabbix_agent2 >/dev/null 2>&1; then
        AGENT_PATH=$(command -v zabbix_agent2)
        AGENT_TYPE="zabbix_agent2"
        AGENT_SERVICE="zabbix-agent2"
        echo -e "${GREEN}✓ Найден агент: $AGENT_PATH${NC}"
    elif command -v zabbix_agentd >/dev/null 2>&1; then
        AGENT_PATH=$(command -v zabbix_agentd)
        AGENT_TYPE="zabbix_agentd"
        AGENT_SERVICE="zabbix-agent"
        echo -e "${GREEN}✓ Найден агент: $AGENT_PATH${NC}"
    fi
fi

if [ -z "$AGENT_PATH" ]; then
    echo -e "${RED}✗ Zabbix Agent не найден${NC}"
    exit 1
fi

AGENT_VERSION=$($AGENT_PATH --version 2>/dev/null | head -1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
echo -e "${GREEN}✓ Версия агента: $AGENT_VERSION${NC}"
echo -e "${GREEN}✓ Сервис: $AGENT_SERVICE${NC}"

for dir in /etc/zabbix/zabbix_agent2.d /etc/zabbix/zabbix_agentd.d /usr/local/etc/zabbix_agentd.d; do
    if [ -d "$dir" ]; then
        AGENT_CONF_DIR="$dir"
        echo -e "${GREEN}✓ Директория конфигов: $AGENT_CONF_DIR${NC}"
        break
    fi
done

if [ -z "$AGENT_CONF_DIR" ]; then
    AGENT_CONF_DIR="/etc/zabbix/zabbix_agentd.d"
    mkdir -p "$AGENT_CONF_DIR"
    echo -e "${YELLOW}✓ Создана директория: $AGENT_CONF_DIR${NC}"
fi

# ============================================================================
# 4. СОЗДАНИЕ СКРИПТА МОНИТОРИНГА (МНОГО СЕРВИСОВ)
# ============================================================================
echo -e "\n${BLUE}[4/8] Создание скрипта мониторинга...${NC}"

sudo tee /usr/local/bin/wb_monitor.sh > /dev/null << 'MONITOR_EOF'
#!/bin/bash
# ============================================================================
# WB Monitor v5.0 - Мониторинг Wildberries (основной + карточки + поиск)
# ============================================================================

# Список сервисов для мониторинга
declare -A SERVICES=(
    ["main"]="wildberries.ru"
    ["card"]="u-card.wb.ru"
    ["search"]="u-search.wb.ru"
)

PING_COUNT=5
PING_TIMEOUT=2
CURL_TIMEOUT=10
CURL_CONNECT_TIMEOUT=5

USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/120.0.0.0 Safari/537.36"

# ===== ФУНКЦИЯ: ПОТЕРИ ПАКЕТОВ ================================================
get_packet_loss() {
    local target=$1
    local output=$(ping -c "$PING_COUNT" -W "$PING_TIMEOUT" "$target" 2>/dev/null)
    local loss=$(echo "$output" | grep -oE '[0-9]+%' | grep -oE '[0-9]+' | head -1)
    if [ -z "$loss" ]; then
        if echo "$output" | grep -q "bytes from"; then
            loss="0"
        else
            loss="100"
        fi
    fi
    echo "$loss"
}

# ===== ФУНКЦИЯ: ВРЕМЯ ПИНГА ==================================================
get_ping_time() {
    local target=$1
    local times=$(ping -c "$PING_COUNT" -W "$PING_TIMEOUT" "$target" 2>/dev/null | grep -oE 'time=[0-9.]+' | cut -d= -f2)
    if [ -n "$times" ]; then
        local sum=0; local count=0
        for t in $times; do sum=$(echo "$sum + $t" | bc); count=$((count + 1)); done
        if [ $count -gt 0 ]; then printf "%.2f" "$(echo "scale=2; $sum / $count" | bc)"; else echo "0"; fi
    else echo "0"; fi
}

# ===== ФУНКЦИЯ: HTTP СТАТУС КОД ===============================================
get_http_code() {
    local target=$1
    local code=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout "$CURL_CONNECT_TIMEOUT" --max-time "$CURL_TIMEOUT" -A "$USER_AGENT" "https://$target" 2>/dev/null)
    echo ${code:-0}
}

# ===== ФУНКЦИЯ: HTTP ВРЕМЯ ОТВЕТА =============================================
get_http_time() {
    local target=$1
    local time_total=$(curl -s -o /dev/null -w "%{time_total}" --connect-timeout "$CURL_CONNECT_TIMEOUT" --max-time "$CURL_TIMEOUT" -A "$USER_AGENT" "https://$target" 2>/dev/null)
    printf "%.3f" "${time_total:-0}"
}

# ===== ДИСПЕТЧЕР =============================================================
case "$1" in
    --loss)         get_packet_loss "${SERVICES[$2]:-$2}" ;;
    --ping-time)    get_ping_time "${SERVICES[$2]:-$2}" ;;
    --http-code)    get_http_code "${SERVICES[$2]:-$2}" ;;
    --http-time)    get_http_time "${SERVICES[$2]:-$2}" ;;
    
    # Основной сервис (для обратной совместимости)
    --main-loss)        get_packet_loss "${SERVICES[main]}" ;;
    --main-ping-time)   get_ping_time "${SERVICES[main]}" ;;
    --main-http-code)   get_http_code "${SERVICES[main]}" ;;
    --main-http-time)   get_http_time "${SERVICES[main]}" ;;
    
    # Карточки
    --card-loss)        get_packet_loss "${SERVICES[card]}" ;;
    --card-ping-time)   get_ping_time "${SERVICES[card]}" ;;
    --card-http-code)   get_http_code "${SERVICES[card]}" ;;
    --card-http-time)   get_http_time "${SERVICES[card]}" ;;
    
    # Поиск
    --search-loss)      get_packet_loss "${SERVICES[search]}" ;;
    --search-ping-time) get_ping_time "${SERVICES[search]}" ;;
    --search-http-code) get_http_code "${SERVICES[search]}" ;;
    --search-http-time) get_http_time "${SERVICES[search]}" ;;
    
    --all-main)
        echo "loss=$(get_packet_loss ${SERVICES[main]}) ping_time=$(get_ping_time ${SERVICES[main]}) http_code=$(get_http_code ${SERVICES[main]}) http_time=$(get_http_time ${SERVICES[main]})"
        ;;
    --all-card)
        echo "loss=$(get_packet_loss ${SERVICES[card]}) ping_time=$(get_ping_time ${SERVICES[card]}) http_code=$(get_http_code ${SERVICES[card]}) http_time=$(get_http_time ${SERVICES[card]})"
        ;;
    --all-search)
        echo "loss=$(get_packet_loss ${SERVICES[search]}) ping_time=$(get_ping_time ${SERVICES[search]}) http_code=$(get_http_code ${SERVICES[search]}) http_time=$(get_http_time ${SERVICES[search]})"
        ;;
    --all)
        echo "=== MAIN (wildberries.ru) ==="
        echo "loss=$(get_packet_loss ${SERVICES[main]}) ping_time=$(get_ping_time ${SERVICES[main]}) http_code=$(get_http_code ${SERVICES[main]}) http_time=$(get_http_time ${SERVICES[main]})"
        echo ""
        echo "=== CARD (u-card.wb.ru) ==="
        echo "loss=$(get_packet_loss ${SERVICES[card]}) ping_time=$(get_ping_time ${SERVICES[card]}) http_code=$(get_http_code ${SERVICES[card]}) http_time=$(get_http_time ${SERVICES[card]})"
        echo ""
        echo "=== SEARCH (u-search.wb.ru) ==="
        echo "loss=$(get_packet_loss ${SERVICES[search]}) ping_time=$(get_ping_time ${SERVICES[search]}) http_code=$(get_http_code ${SERVICES[search]}) http_time=$(get_http_time ${SERVICES[search]})"
        ;;
    --version)
        echo "5.0"
        ;;
    --help|-h)
        cat << 'HELP_EOF'
WB Monitor v5.0 - Мониторинг Wildberries

Использование:
  Основной сервер (wildberries.ru):
    wb_monitor.sh --main-loss
    wb_monitor.sh --main-ping-time
    wb_monitor.sh --main-http-code
    wb_monitor.sh --main-http-time
    wb_monitor.sh --all-main

  Карточки (u-card.wb.ru):
    wb_monitor.sh --card-loss
    wb_monitor.sh --card-ping-time
    wb_monitor.sh --card-http-code
    wb_monitor.sh --card-http-time
    wb_monitor.sh --all-card

  Поиск (u-search.wb.ru):
    wb_monitor.sh --search-loss
    wb_monitor.sh --search-ping-time
    wb_monitor.sh --search-http-code
    wb_monitor.sh --search-http-time
    wb_monitor.sh --all-search

  Общее:
    wb_monitor.sh --all      - Все сервисы
    wb_monitor.sh --version  - Версия
    wb_monitor.sh --help     - Справка
HELP_EOF
        ;;
    *)
        echo "Использование: $0 {--main-loss|--card-loss|--search-loss|--all|--help}"
        exit 1
        ;;
esac
MONITOR_EOF

sudo chmod +x /usr/local/bin/wb_monitor.sh
echo -e "${GREEN}✓ Скрипт создан: /usr/local/bin/wb_monitor.sh${NC}"

# ============================================================================
# 5. СОЗДАНИЕ КОНФИГА ZABBIX AGENT
# ============================================================================
echo -e "\n${BLUE}[5/8] Создание конфига Zabbix Agent...${NC}"

CONF_FILE="$AGENT_CONF_DIR/wb_monitor.conf"

sudo tee "$CONF_FILE" > /dev/null << 'CONF_EOF'
# WB Monitor v5.0 - Конфигурация для Zabbix Agent
# ============================================================================

# Основной сервер (wildberries.ru)
UserParameter=wb.main.loss, /usr/local/bin/wb_monitor.sh --main-loss
UserParameter=wb.main.ping.time, /usr/local/bin/wb_monitor.sh --main-ping-time
UserParameter=wb.main.http.code, /usr/local/bin/wb_monitor.sh --main-http-code
UserParameter=wb.main.http.time, /usr/local/bin/wb_monitor.sh --main-http-time

# Карточки (u-card.wb.ru)
UserParameter=wb.card.loss, /usr/local/bin/wb_monitor.sh --card-loss
UserParameter=wb.card.ping.time, /usr/local/bin/wb_monitor.sh --card-ping-time
UserParameter=wb.card.http.code, /usr/local/bin/wb_monitor.sh --card-http-code
UserParameter=wb.card.http.time, /usr/local/bin/wb_monitor.sh --card-http-time

# Поиск (u-search.wb.ru)
UserParameter=wb.search.loss, /usr/local/bin/wb_monitor.sh --search-loss
UserParameter=wb.search.ping.time, /usr/local/bin/wb_monitor.sh --search-ping-time
UserParameter=wb.search.http.code, /usr/local/bin/wb_monitor.sh --search-http-code
UserParameter=wb.search.http.time, /usr/local/bin/wb_monitor.sh --search-http-time

# Версия
UserParameter=wb.version, /usr/local/bin/wb_monitor.sh --version
CONF_EOF

echo -e "${GREEN}✓ Конфиг создан: $CONF_FILE${NC}"

# ============================================================================
# 6. СОЗДАНИЕ СКРИПТА АВТООБНОВЛЕНИЯ
# ============================================================================
echo -e "\n${BLUE}[6/8] Создание скрипта автообновления...${NC}"

sudo tee /usr/local/bin/update_wb_monitor.sh > /dev/null << 'UPDATE_EOF'
#!/bin/bash
# WB Monitor - Скрипт автообновления

GITHUB_URL="https://raw.githubusercontent.com/briannikolson/scripts/refs/heads/main/install_wb_monitor"
LOCAL_SCRIPT="/usr/local/bin/wb_monitor.sh"
LOG_FILE="/var/log/wb_monitor_update.log"

log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "$LOG_FILE"
}

TEMP_SCRIPT="/tmp/wb_monitor_new.sh"
curl -s "$GITHUB_URL" -o "$TEMP_SCRIPT"

if [ ! -s "$TEMP_SCRIPT" ]; then
    log "ERROR: Failed to download from GitHub"
    rm -f "$TEMP_SCRIPT"
    exit 1
fi

if ! cmp -s "$TEMP_SCRIPT" "$LOCAL_SCRIPT"; then
    log "New version detected, updating..."
    cp "$LOCAL_SCRIPT" "${LOCAL_SCRIPT}.bak"
    cp "$TEMP_SCRIPT" "$LOCAL_SCRIPT"
    chmod +x "$LOCAL_SCRIPT"
    
    if systemctl restart zabbix-agent2 2>/dev/null; then
        log "Zabbix Agent2 restarted successfully"
    elif systemctl restart zabbix-agent 2>/dev/null; then
        log "Zabbix Agent restarted successfully"
    fi
    
    log "Update completed successfully"
else
    log "No changes detected"
fi

rm -f "$TEMP_SCRIPT"
UPDATE_EOF

sudo chmod +x /usr/local/bin/update_wb_monitor.sh
echo -e "${GREEN}✓ Скрипт автообновления создан${NC}"

# ============================================================================
# 7. НАСТРОЙКА АВТООБНОВЛЕНИЯ
# ============================================================================
echo -e "\n${BLUE}[7/8] Настройка автообновления...${NC}"

if ! crontab -l 2>/dev/null | grep -q "update_wb_monitor.sh"; then
    (crontab -l 2>/dev/null; echo "*/5 * * * * /usr/local/bin/update_wb_monitor.sh > /dev/null 2>&1") | crontab -
    echo -e "${GREEN}✓ Добавлена задача в cron (каждые 5 минут)${NC}"
else
    echo -e "${GREEN}✓ Задача в cron уже существует${NC}"
fi

touch /var/log/wb_monitor_update.log
chmod 644 /var/log/wb_monitor_update.log

# ============================================================================
# 8. ПЕРЕЗАПУСК И ПРОВЕРКА
# ============================================================================
echo -e "\n${BLUE}[8/8] Перезапуск и проверка...${NC}"

if systemctl restart "$AGENT_SERVICE" 2>/dev/null; then
    echo -e "${GREEN}✓ Агент перезапущен: systemctl restart $AGENT_SERVICE${NC}"
else
    for alt in zabbix-agent2 zabbix-agent zabbix_agentd; do
        if systemctl restart "$alt" 2>/dev/null; then
            echo -e "${GREEN}✓ Агент перезапущен: systemctl restart $alt${NC}"
            break
        fi
    done
fi

sleep 2

echo -e "\n${YELLOW}Результаты мониторинга:${NC}"
/usr/local/bin/wb_monitor.sh --all

echo -e "\n${YELLOW}Проверка через Zabbix Agent:${NC}"
if command -v zabbix_get >/dev/null 2>&1; then
    echo -n "  wb.main.loss:      "
    zabbix_get -s 127.0.0.1 -k wb.main.loss 2>/dev/null || echo "недоступно"
    echo -n "  wb.card.loss:      "
    zabbix_get -s 127.0.0.1 -k wb.card.loss 2>/dev/null || echo "недоступно"
    echo -n "  wb.search.loss:    "
    zabbix_get -s 127.0.0.1 -k wb.search.loss 2>/dev/null || echo "недоступно"
else
    echo -e "${YELLOW}⚠ zabbix_get не установлен${NC}"
fi

# ============================================================================
# ИТОГ
# ============================================================================
echo -e "\n${GREEN}========================================${NC}"
echo -e "${GREEN}УСТАНОВКА ЗАВЕРШЕНА!${NC}"
echo -e "${GREEN}========================================${NC}"
echo -e ""
echo -e "${BLUE}Мониторинг сервисов:${NC}"
echo -e "  🌐 Основной:    wildberries.ru"
echo -e "  🃏 Карточки:    u-card.wb.ru"
echo -e "  🔍 Поиск:       u-search.wb.ru"
echo -e ""
echo -e "${BLUE}Метрики для Zabbix (12 шт):${NC}"
echo -e "  wb.main.loss, wb.main.ping.time, wb.main.http.code, wb.main.http.time"
echo -e "  wb.card.loss, wb.card.ping.time, wb.card.http.code, wb.card.http.time"
echo -e "  wb.search.loss, wb.search.ping.time, wb.search.http.code, wb.search.http.time"
echo -e ""
echo -e "${BLUE}Проверка:${NC}"
echo -e "  /usr/local/bin/wb_monitor.sh --all"
echo -e "  /usr/local/bin/wb_monitor.sh --main-loss"
echo -e "  /usr/local/bin/wb_monitor.sh --card-http-code"
echo -e "  /usr/local/bin/wb_monitor.sh --search-ping-time"
echo -e ""
echo -e "${GREEN}Готово! 🚀${NC}"
