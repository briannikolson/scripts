#!/bin/bash
# ============================================================================
# WB Monitor - Полная автоматическая установка
# Финальная версия
# ============================================================================

set -e

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${GREEN}========================================${NC}"
echo -e "${GREEN}WB Monitor - Финальная установка${NC}"
echo -e "${GREEN}========================================${NC}"

# ============================================================================
# 1. УСТАНОВКА ЗАВИСИМОСТЕЙ
# ============================================================================
echo -e "\n${BLUE}[1/5] Установка зависимостей...${NC}"

install_if_missing() {
    if ! command -v $1 >/dev/null 2>&1; then
        echo -e "${YELLOW}Установка $1...${NC}"
        if command -v apt >/dev/null 2>&1; then
            sudo apt update && sudo apt install -y $1
        elif command -v yum >/dev/null 2>&1; then
            sudo yum install -y $1
        elif command -v dnf >/dev/null 2>&1; then
            sudo dnf install -y $1
        elif command -v apk >/dev/null 2>&1; then
            sudo apk add $1
        else
            echo "Не удалось установить $1. Установите вручную."
            return 1
        fi
        echo -e "${GREEN}✓ $1 установлен${NC}"
    else
        echo -e "${GREEN}✓ $1 уже установлен${NC}"
    fi
}

install_if_missing "curl"
install_if_missing "bc"

# ============================================================================
# 2. ПОИСК ZABBIX AGENT
# ============================================================================
echo -e "\n${BLUE}[2/5] Поиск Zabbix Agent...${NC}"

AGENT_SERVICE=""
if systemctl list-units --type=service | grep -q "zabbix-agent2"; then
    AGENT_SERVICE="zabbix-agent2"
    echo -e "${GREEN}✓ Найден Zabbix Agent 2${NC}"
elif systemctl list-units --type=service | grep -q "zabbix-agent"; then
    AGENT_SERVICE="zabbix-agent"
    echo -e "${GREEN}✓ Найден Zabbix Agent${NC}"
else
    echo -e "${YELLOW}⚠ Zabbix Agent не найден. Установите его вручную.${NC}"
fi

# ============================================================================
# 3. СОЗДАНИЕ СКРИПТА МОНИТОРИНГА
# ============================================================================
echo -e "\n${BLUE}[3/5] Создание скрипта мониторинга...${NC}"

cat > /usr/local/bin/wb_monitor.sh << 'MONITOR_EOF'
#!/bin/bash
# WB Monitor - Финальная версия

TARGET="wildberries.ru"
CURL_TIMEOUT=10
CURL_CONNECT_TIMEOUT=5

get_http_code() {
    local code=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout "$CURL_CONNECT_TIMEOUT" --max-time "$CURL_TIMEOUT" "https://$TARGET" 2>/dev/null)
    echo ${code:-0}
}

get_http_time() {
    local time_total=$(curl -s -o /dev/null -w "%{time_total}" --connect-timeout "$CURL_CONNECT_TIMEOUT" --max-time "$CURL_TIMEOUT" "https://$TARGET" 2>/dev/null)
    printf "%.3f" "${time_total:-0}"
}

get_packet_loss() {
    local code=$(get_http_code)
    if [ "$code" = "200" ] || [ "$code" = "301" ] || [ "$code" = "302" ] || [ "$code" = "307" ]; then
        echo "0"
    else
        echo "100"
    fi
}

get_ping_time() {
    local time_sec=$(get_http_time)
    if [ "$time_sec" != "0" ]; then
        printf "%.0f" "$(echo "$time_sec * 1000" | bc 2>/dev/null || echo "0")"
    else
        echo "0"
    fi
}

case "$1" in
    --loss) get_packet_loss ;;
    --ping-time) get_ping_time ;;
    --http-code) get_http_code ;;
    --http-time) get_http_time ;;
    --all) echo "loss=$(get_packet_loss) ping_time=$(get_ping_time) http_code=$(get_http_code) http_time=$(get_http_time)" ;;
    *) exit 1 ;;
esac
MONITOR_EOF

chmod +x /usr/local/bin/wb_monitor.sh
echo -e "${GREEN}✓ Скрипт создан: /usr/local/bin/wb_monitor.sh${NC}"

# ============================================================================
# 4. НАСТРОЙКА ZABBIX AGENT
# ============================================================================
echo -e "\n${BLUE}[4/5] Настройка Zabbix Agent...${NC}"

# Определяем директорию конфигов
if [ -d "/etc/zabbix/zabbix_agent2.d" ]; then
    CONF_DIR="/etc/zabbix/zabbix_agent2.d"
elif [ -d "/etc/zabbix/zabbix_agentd.d" ]; then
    CONF_DIR="/etc/zabbix/zabbix_agentd.d"
else
    CONF_DIR="/etc/zabbix/zabbix_agentd.d"
    mkdir -p "$CONF_DIR"
fi

cat > "$CONF_DIR/wb_monitor.conf" << 'CONF_EOF'
UserParameter=wb.loss, /usr/local/bin/wb_monitor.sh --loss
UserParameter=wb.ping.time, /usr/local/bin/wb_monitor.sh --ping-time
UserParameter=wb.http.code, /usr/local/bin/wb_monitor.sh --http-code
UserParameter=wb.http.time, /usr/local/bin/wb_monitor.sh --http-time
CONF_EOF

echo -e "${GREEN}✓ Конфиг создан: $CONF_DIR/wb_monitor.conf${NC}"

# ============================================================================
# 5. ПЕРЕЗАПУСК И ПРОВЕРКА
# ============================================================================
echo -e "\n${BLUE}[5/5] Перезапуск и проверка...${NC}"

if [ -n "$AGENT_SERVICE" ]; then
    sudo systemctl restart "$AGENT_SERVICE"
    echo -e "${GREEN}✓ Агент перезапущен: $AGENT_SERVICE${NC}"
else
    echo -e "${YELLOW}⚠ Перезапустите Zabbix Agent вручную${NC}"
fi

sleep 2

echo -e "\n${YELLOW}Результаты мониторинга:${NC}"
/usr/local/bin/wb_monitor.sh --all

echo -e "\n${GREEN}========================================${NC}"
echo -e "${GREEN}УСТАНОВКА ЗАВЕРШЕНА!${NC}"
echo -e "${GREEN}========================================${NC}"
echo -e ""
echo -e "Метрики для Zabbix:"
echo -e "  wb.loss        - Потери пакетов (0% = OK)"
echo -e "  wb.ping.time   - Время отклика (мс)"
echo -e "  wb.http.code   - HTTP статус (307 = OK)"
echo -e "  wb.http.time   - Время ответа (сек)"
echo -e ""
echo -e "Создайте шаблон в Zabbix с этими ключами и назначьте на хост."
